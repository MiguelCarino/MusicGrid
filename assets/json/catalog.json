   COUNTRIES : country menu  -> { id: {name, flag} }
   GENRES    : genre menu     -> { id: {name, icon} }
   MOODS     : mood menu      -> { id: {name, icon} }
   albums    : one entry per song:
     url          YouTube video id (the player source)
     image        cover file in assets/covers/
     tag          "Artist — Title" (tooltip + now-playing)
     country/genre/mood   ids keying into the registries above
     carino       true = part of Miguel's personal list
     spotifyurl   Spotify track id, or '' to link a search by tag
     applemusicurl Apple Music path, or '' to link a search by tag
   ============================================================ */

